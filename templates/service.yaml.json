{
  "template_name": "service.yaml",
  "description": "Kubernetes Service manifest (ClusterIP, NodePort, LoadBalancer)",
  "variables": [
    {
      "name": "app_name",
      "description": "Name of the application",
      "type": "string",
      "required": true,
      "default": ""
    },
    {
      "name": "namespace",
      "description": "Kubernetes namespace",
      "type": "string",
      "required": false,
      "default": "default"
    },
    {
      "name": "service_type",
      "description": "Service type (ClusterIP, NodePort, LoadBalancer)",
      "type": "string",
      "required": false,
      "default": "ClusterIP"
    },
    {
      "name": "service_port",
      "description": "Service port",
      "type": "int",
      "required": false,
      "default": "80"
    },
    {
      "name": "target_port",
      "description": "Container target port",
      "type": "int",
      "required": false,
      "default": "8080"
    },
    {
      "name": "protocol",
      "description": "Protocol (TCP, UDP)",
      "type": "string",
      "required": false,
      "default": "TCP"
    }
  ]
}
