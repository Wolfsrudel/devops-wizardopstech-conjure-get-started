global:
  scrape_interval: {{.scrape_interval}}
  evaluation_interval: {{.evaluation_interval}}
  scrape_timeout: {{.scrape_timeout}}

  external_labels:
    cluster: 'production'
    replica: '1'

alerting:
  alertmanagers:
    - static_configs:
        - targets: []

rule_files:
  # - "alerts/*.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: '{{.app_name}}'
    static_configs:
      - targets:
{{range $target := split .app_targets ","}}          - '{{$target}}'
{{end}}    metrics_path: /metrics
    scrape_interval: {{.scrape_interval}}
{{if .enable_node_exporter}}

  - job_name: 'node-exporter'
    static_configs:
      - targets:
{{range $target := split .node_exporter_targets ","}}          - '{{$target}}'
{{end}}{{end}}
