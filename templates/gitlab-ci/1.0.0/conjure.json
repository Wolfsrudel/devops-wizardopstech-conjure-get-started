{
  "schema_version": "v1",
  "template_name": ".gitlab-ci.yml",
  "template_description": "GitLab CI pipeline for build, test, and deploy",
  "template_type": "ci-cd",
  "variables": [
    {
      "name": "app_name",
      "description": "Application name",
      "type": "string",
      "default": ""
    },
    {
      "name": "node_version",
      "description": "Node.js version",
      "type": "string",
      "default": "20"
    },
    {
      "name": "run_tests",
      "description": "Run test suite",
      "type": "bool",
      "default": "true"
    },
    {
      "name": "run_linter",
      "description": "Run linter",
      "type": "bool",
      "default": "true"
    },
    {
      "name": "build_docker_image",
      "description": "Build Docker image",
      "type": "bool",
      "default": "true"
    },
    {
      "name": "docker_registry",
      "description": "Docker registry",
      "type": "string",
      "default": "$CI_REGISTRY"
    },
    {
      "name": "docker_image_name",
      "description": "Docker image name",
      "type": "string",
      "default": ""
    }
  ]
}
