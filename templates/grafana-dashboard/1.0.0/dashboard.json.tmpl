{
  "dashboard": {
    "title": "{{.dashboard_title}}",
    "tags": ["{{.app_name}}", "monitoring"],
    "timezone": "browser",
    "refresh": "{{.refresh_interval}}",
    "schemaVersion": 16,
    "version": 1,
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"{{.app_name}}\"}[5m])",
            "legendFormat": "{{"{{"}}method{{"}}"}} {{"{{"}}status{{"}}"}}",
            "refId": "A"
          }
        ],
        "datasource": "{{.datasource}}",
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Response Time (95th percentile)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"{{.app_name}}\"}[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          }
        ],
        "datasource": "{{.datasource}}",
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"{{.app_name}}\",status=~\"5..\"}[5m])",
            "legendFormat": "5xx errors",
            "refId": "A"
          }
        ],
        "datasource": "{{.datasource}}",
        "yaxes": [
          {"format": "reqps", "label": "Errors/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"{{.app_name}}\"}",
            "legendFormat": "RSS",
            "refId": "A"
          }
        ],
        "datasource": "{{.datasource}}",
        "yaxes": [
          {"format": "bytes", "label": "Memory"},
          {"format": "short"}
        ]
      }
    ]
  }
}
