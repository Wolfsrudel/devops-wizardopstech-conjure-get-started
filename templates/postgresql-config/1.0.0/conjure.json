{
  "schema_version": "v1",
  "template_name": "postgresql.conf",
  "template_description": "PostgreSQL server configuration",
  "template_type": "config",
  "variables": [
    {
      "name": "port",
      "description": "PostgreSQL port",
      "type": "int",
      "default": "5432"
    },
    {
      "name": "max_connections",
      "description": "Maximum connections",
      "type": "int",
      "default": "100"
    },
    {
      "name": "shared_buffers",
      "description": "Shared buffers (e.g., 256MB, 1GB)",
      "type": "string",
      "default": "256MB"
    },
    {
      "name": "effective_cache_size",
      "description": "Effective cache size",
      "type": "string",
      "default": "1GB"
    },
    {
      "name": "work_mem",
      "description": "Work memory per operation",
      "type": "string",
      "default": "4MB"
    },
    {
      "name": "maintenance_work_mem",
      "description": "Maintenance work memory",
      "type": "string",
      "default": "64MB"
    },
    {
      "name": "log_level",
      "description": "Log level (debug, info, notice, warning, error)",
      "type": "string",
      "default": "warning"
    },
    {
      "name": "enable_statement_logging",
      "description": "Log all SQL statements",
      "type": "bool",
      "default": "false"
    }
  ]
}
