apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{.app_name}}
  namespace: argocd
  labels:
    app: {{.app_name}}
  finalizers:
  - resources-finalizer.argocd.argoproj.io
spec:
  project: {{.project}}
  source:
    repoURL: {{.repo_url}}
    targetRevision: {{.target_revision}}
    path: {{.path}}
  destination:
    server: https://kubernetes.default.svc
    namespace: {{.namespace}}
{{if .auto_sync}}  syncPolicy:
    automated:
      prune: {{.prune}}
      selfHeal: {{.self_heal}}
    syncOptions:
    - CreateNamespace=true
    - PruneLast=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m
{{end}}
