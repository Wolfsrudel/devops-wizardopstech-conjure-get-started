{
  "template_name": "docker-compose.yaml",
  "description": "Docker Compose configuration for local development",
  "variables": [
    {
      "name": "app_name",
      "description": "Application name",
      "type": "string",
      "required": true,
      "default": ""
    },
    {
      "name": "app_port",
      "description": "Application port",
      "type": "int",
      "required": false,
      "default": "8080"
    },
    {
      "name": "include_database",
      "description": "Include PostgreSQL database",
      "type": "bool",
      "required": false,
      "default": "true"
    },
    {
      "name": "include_redis",
      "description": "Include Redis cache",
      "type": "bool",
      "required": false,
      "default": "false"
    },
    {
      "name": "postgres_version",
      "description": "PostgreSQL version",
      "type": "string",
      "required": false,
      "default": "15-alpine"
    },
    {
      "name": "redis_version",
      "description": "Redis version",
      "type": "string",
      "required": false,
      "default": "7-alpine"
    }
  ]
}
