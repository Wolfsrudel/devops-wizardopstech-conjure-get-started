{
  "schema_version": "v1",
  "template_name": "main.tf",
  "template_description": "Terraform configuration for Azure Virtual Machine",
  "template_type": "terraform",
  "variables": [
    {
      "name": "vm_name",
      "description": "Virtual Machine name",
      "type": "string",
      "default": ""
    },
    {
      "name": "resource_group_name",
      "description": "Resource group name",
      "type": "string",
      "default": ""
    },
    {
      "name": "location",
      "description": "Azure region",
      "type": "string",
      "default": "eastus"
    },
    {
      "name": "vm_size",
      "description": "VM size",
      "type": "string",
      "default": "Standard_B2s"
    },
    {
      "name": "admin_username",
      "description": "Admin username",
      "type": "string",
      "default": "azureuser"
    },
    {
      "name": "ssh_public_key",
      "description": "SSH public key",
      "type": "string",
      "default": ""
    },
    {
      "name": "os_disk_size_gb",
      "description": "OS disk size in GB",
      "type": "int",
      "default": "30"
    },
    {
      "name": "enable_public_ip",
      "description": "Create public IP address",
      "type": "bool",
      "default": "true"
    },
    {
      "name": "environment",
      "description": "Environment tag (dev, staging, prod)",
      "type": "string",
      "default": "dev"
    }
  ]
}
