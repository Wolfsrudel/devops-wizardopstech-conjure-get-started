terraform {
  required_version = ">= 1.0"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = "{{.project_id}}"
  region  = "{{.region}}"
}

resource "google_compute_network" "{{.instance_name}}_network" {
  name                    = "{{.instance_name}}-network"
  auto_create_subnetworks = false
}

resource "google_compute_subnetwork" "{{.instance_name}}_subnet" {
  name          = "{{.instance_name}}-subnet"
  ip_cidr_range = "10.0.0.0/24"
  region        = "{{.region}}"
  network       = google_compute_network.{{.instance_name}}_network.id
}

resource "google_compute_firewall" "{{.instance_name}}_firewall" {
  name    = "{{.instance_name}}-firewall"
  network = google_compute_network.{{.instance_name}}_network.name

  allow {
    protocol = "tcp"
    ports    = ["22", "80", "443"]
  }

  source_ranges = ["0.0.0.0/0"]
  target_tags   = ["{{.instance_name}}"]
}

resource "google_compute_instance" "{{.instance_name}}" {
  name         = "{{.instance_name}}"
  machine_type = "{{.machine_type}}"
  zone         = "{{.zone}}"

  tags = ["{{.instance_name}}"]

  boot_disk {
    initialize_params {
      image = "ubuntu-os-cloud/ubuntu-2204-lts"
      size  = {{.boot_disk_size_gb}}
      type  = "pd-standard"
    }
  }

  network_interface {
    network    = google_compute_network.{{.instance_name}}_network.id
    subnetwork = google_compute_subnetwork.{{.instance_name}}_subnet.id
{{if .enable_public_ip}}
    access_config {
      // Ephemeral public IP
    }
{{end}}  }

  metadata = {
    ssh-keys = "{{.ssh_user}}:{{.ssh_public_key}}"
  }

  labels = {
    environment = "{{.environment}}"
  }

  shielded_instance_config {
    enable_secure_boot          = true
    enable_vtpm                 = true
    enable_integrity_monitoring = true
  }
}

output "instance_id" {
  description = "Compute instance ID"
  value       = google_compute_instance.{{.instance_name}}.instance_id
}
{{if .enable_public_ip}}
output "public_ip" {
  description = "External IP address"
  value       = google_compute_instance.{{.instance_name}}.network_interface[0].access_config[0].nat_ip
}
{{end}}
output "private_ip" {
  description = "Internal IP address"
  value       = google_compute_instance.{{.instance_name}}.network_interface[0].network_ip
}
