# Environment Configuration for {{ .app_name }}
# Environment: {{ .environment }}

# Application
APP_NAME={{ .app_name }}
NODE_ENV={{ .environment }}
PORT={{ .port }}
LOG_LEVEL={{ .log_level }}

# Database
DATABASE_URL={{ .database_url }}

# Redis
REDIS_URL={{ .redis_url }}

# Security
JWT_SECRET={{ .jwt_secret }}
ENABLE_CORS={{ .enable_cors }}

# Feature Flags
{{- if eq .environment "production" }}
DEBUG=false
ENABLE_SWAGGER=false
{{- else }}
DEBUG=true
ENABLE_SWAGGER=true
{{- end }}
