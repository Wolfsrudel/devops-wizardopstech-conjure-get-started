# {{ .language }} .gitignore

{{- if eq .language "nodejs" }}
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
.nuxt/
.cache/
coverage/
.nyc_output/
*.tsbuildinfo
.eslintcache

{{- else if eq .language "python" }}
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
ENV/

{{- else if eq .language "go" }}
# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
vendor/

{{- else if eq .language "java" }}
# Java
*.class
*.jar
*.war
*.ear
*.log
target/
.mvn/
.gradle/
build/
.settings/
.classpath
.project

{{- end }}

# Environment files
.env
.env.local
.env.*.local
*.env

# Secrets
secrets/
*.key
*.pem
*.crt

# Logs
logs/
*.log

{{- if .include_docker }}

# Docker
.dockerignore
docker-compose.override.yml

{{- end }}

{{- if .include_ide }}

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

{{- end }}

{{- if .include_os }}

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

{{- end }}
