{
  "schema_version": "v1",
  "bundle_type": "docker",
  "bundle_name": "docker-stack",
  "bundle_description": "Complete Docker development stack (Docker Compose + Dockerfile)",
  "shared_variables": [
    {
      "name": "app_name",
      "description": "Application name",
      "type": "string",
      "default": ""
    },
    {
      "name": "node_version",
      "description": "Node.js version",
      "type": "string",
      "default": "20-alpine"
    }
  ],
  "template_variables": {
    "docker-compose.yml.tmpl": [
      {
        "name": "app_port",
        "description": "Application port",
        "type": "int",
        "default": "8080"
      },
      {
        "name": "include_database",
        "description": "Include PostgreSQL service",
        "type": "bool",
        "default": "true"
      },
      {
        "name": "include_redis",
        "description": "Include Redis service",
        "type": "bool",
        "default": "true"
      },
      {
        "name": "postgres_version",
        "description": "PostgreSQL version",
        "type": "string",
        "default": "16-alpine"
      },
      {
        "name": "redis_version",
        "description": "Redis version",
        "type": "string",
        "default": "7-alpine"
      }
    ],
    "Dockerfile.tmpl": [
      {
        "name": "expose_port",
        "description": "Port to expose in Dockerfile",
        "type": "int",
        "default": "8080"
      },
      {
        "name": "build_command",
        "description": "Build command",
        "type": "string",
        "default": "npm run build"
      },
      {
        "name": "start_command",
        "description": "Start command",
        "type": "string",
        "default": "npm start"
      }
    ]
  }
}
