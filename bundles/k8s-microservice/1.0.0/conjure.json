{
  "schema_version": "v1",
  "bundle_type": "kubernetes",
  "bundle_name": "k8s-microservice",
  "bundle_description": "Kubernetes microservice with observability (Deployment + Service + ConfigMap + ServiceMonitor)",
  "shared_variables": [
    {
      "name": "app_name",
      "description": "Application name",
      "type": "string",
      "default": ""
    },
    {
      "name": "namespace",
      "description": "Kubernetes namespace",
      "type": "string",
      "default": "default"
    },
    {
      "name": "image",
      "description": "Container image",
      "type": "string",
      "default": ""
    },
    {
      "name": "replicas",
      "description": "Number of replicas",
      "type": "int",
      "default": "3"
    },
    {
      "name": "container_port",
      "description": "Container port",
      "type": "int",
      "default": "8080"
    },
    {
      "name": "log_level",
      "description": "Log level",
      "type": "string",
      "default": "info"
    },
    {
      "name": "enable_metrics",
      "description": "Enable Prometheus metrics",
      "type": "bool",
      "default": "true"
    }
  ],
  "template_variables": {}
}
