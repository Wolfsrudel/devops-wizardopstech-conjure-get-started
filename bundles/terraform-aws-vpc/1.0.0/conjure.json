{
  "schema_version": "v1",
  "bundle_type": "terraform",
  "bundle_name": "terraform-aws-vpc",
  "bundle_description": "Complete AWS VPC with subnets, IGW, and route tables",
  "shared_variables": [
    {
      "name": "vpc_name",
      "description": "VPC name",
      "type": "string",
      "default": ""
    },
    {
      "name": "region",
      "description": "AWS region",
      "type": "string",
      "default": "us-east-1"
    },
    {
      "name": "vpc_cidr",
      "description": "VPC CIDR block",
      "type": "string",
      "default": "10.0.0.0/16"
    },
    {
      "name": "enable_nat_gateway",
      "description": "Enable NAT Gateway",
      "type": "bool",
      "default": "true"
    },
    {
      "name": "environment",
      "description": "Environment tag",
      "type": "string",
      "default": "dev"
    }
  ],
  "template_variables": {}
}
